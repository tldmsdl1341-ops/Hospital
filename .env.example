# Copy to .env.local and adjust for your machine.
NEXT_PUBLIC_API_URL=http://localhost:9695

# local: each developer uses own SeaweedFS (localhost:8888)
# team : point to shared team SeaweedFS server
NEXT_PUBLIC_STORAGE_PROFILE=local
NEXT_PUBLIC_SEAWEEDFS_PUBLIC_BASE_URL=http://localhost:8888

# Team example:
# NEXT_PUBLIC_STORAGE_PROFILE=team
# NEXT_PUBLIC_SEAWEEDFS_PUBLIC_BASE_URL=http://192.168.0.10:8888
